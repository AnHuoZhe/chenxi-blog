<!doctype html>
<html lang="zh-CN"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{ title or site.name }} · 晨汐博客</title><link rel="stylesheet" href="{{ '/styles.css' | url }}"></head>
<body><a class="skip-link" href="#main-content">跳至主要内容</a><header class="site-header"><div class="site-header__inner"><a class="brand" href="{{ '/' | url }}">晨汐<span>的学习地图</span></a><div class="site-actions"><button class="menu-toggle" type="button" aria-controls="site-navigation" aria-expanded="false"><span class="visually-hidden">展开导航</span><span aria-hidden="true">菜单</span></button><button class="theme-toggle" type="button" aria-label="切换颜色主题"><span aria-hidden="true">◐</span></button></div><nav class="site-nav" id="site-navigation" aria-label="主导航"><a href="{{ '/' | url }}" {% if page.url == '/' %}aria-current="page"{% endif %}>首页</a><a href="{{ '/个体/' | url }}" {% if page.url.includes('/个体/') %}aria-current="page"{% endif %}>个体</a><a href="{{ '/我的感悟/' | url }}" {% if page.url.includes('/我的感悟/') %}aria-current="page"{% endif %}>我的感悟</a></nav></div></header>
<main id="main-content" tabindex="-1">{{ content | safe }}</main><footer class="site-footer">晨汐的技术花园 · 持续生长中</footer><script src="{{ '/scripts/site.js' | url }}" defer></script></body></html>
